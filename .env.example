LOOKER_BASE_URL=https://your-company.looker.com
LOOKER_CLIENT_ID=your_client_id_here
LOOKER_CLIENT_SECRET=your_client_secret_here
PORT=3045

# Optional: enables the ✨ AI insight button on tiles (Anthropic API key).
# Get one at https://console.anthropic.com → API Keys.
# ANTHROPIC_API_KEY=sk-ant-...

# First-run admin account (seeded only if no users exist yet).
ADMIN_EMAIL=admin@howler.co.za
ADMIN_PASSWORD=change_me_after_first_login

# Optional: secret used to sign session cookies. If unset, a random one is
# generated and saved to server/data/.session-secret. Set it explicitly in
# production so sessions survive across deploys.
# SESSION_SECRET=some_long_random_string

# ─── Production ────────────────────────────────────────────────────────────
# Set NODE_ENV=production behind HTTPS: makes the session cookie Secure and
# enables 'trust proxy' (for Caddy/Nginx). Override individually if needed.
# NODE_ENV=production
# COOKIE_SECURE=1
# TRUST_PROXY=1

# Where the SQLite database + session secret live. Point this at a PERSISTENT
# disk in production (e.g. /var/lib/pulse). Defaults to server/data.
# DATA_DIR=/var/lib/pulse

# ─── Performance / scaling knobs ───────────────────────────────────────────
# Query cache: seconds a Looker result is "fresh", then how long it can be
# served stale while it refreshes in the background, and max cached entries.
# QUERY_CACHE_TTL=60
# QUERY_CACHE_STALE=600
# QUERY_CACHE_MAX=500
# Max concurrent outbound Looker requests (spikes queue instead of overloading
# Looker / BigQuery). Raise/lower to match your Looker plan's limits.
# LOOKER_MAX_CONCURRENCY=8

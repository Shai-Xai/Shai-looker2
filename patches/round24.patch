diff --git a/test/staffAlerts.test.js b/test/staffAlerts.test.js
index 1d7ede0..668fc28 100644
--- a/test/staffAlerts.test.js
+++ b/test/staffAlerts.test.js
@@ -86,0 +87,11 @@ test('storm guard: many stations crossing together send ONE site-wide note', ()
+test('a paused event fires nothing until resumed', () => {
+  const h = mountAlerts();
+  seed(h, { on: 2, off: 2 });
+  db.setSetting('staff_alerts_paused_su1', '1');
+  h.mod.tick();
+  assert.equal(h.testEmails.length, 0);
+  db.setSetting('staff_alerts_paused_su1', '0');
+  h.mod.tick();
+  assert.equal(h.testEmails.length, 1);
+});
+

@@ -46,0 +47,4 @@ export default function SingleValueTile({ data, visConfig = {}, label }) {
+  // 📱 Phones abbreviate big figures (2,701,926.00 → 2.7M) so the number never
+  // outgrows its tile; any currency prefix survives, percentages stay exact,
+  // and desktop keeps the full figure. Tap-to-drill still shows every digit.
+  const shownValue = isMobile ? compactNumber(primaryValue, primaryCell?.value) : primaryValue;
@@ -114 +118 @@ export default function SingleValueTile({ data, visConfig = {}, label }) {
-        <CountUpValue text={primaryValue} />
+        <CountUpValue text={shownValue} />
@@ -130,0 +135,15 @@ export default function SingleValueTile({ data, visConfig = {}, label }) {
+// 2,701,926.00 → 2.7M · 896,486.00 → 896K · 48,469.00 → 48.5K. Keeps a
+// currency/unit prefix ("€", "R "), leaves percentages and small numbers
+// exactly as Looker rendered them.
+function compactNumber(txt, raw) {
+  const n = Number(raw);
+  if (!Number.isFinite(n) || Math.abs(n) < 10000) return txt;
+  const s = String(txt);
+  if (s.trim().endsWith('%')) return txt;
+  const pre = (s.match(/^\s*([^0-9\-+.]*)/) || [])[1] || '';
+  const abs = Math.abs(n);
+  const one = (v) => (v >= 100 ? String(Math.round(v)) : v.toFixed(1).replace(/\.0$/, ''));
+  const body = abs >= 1e9 ? `${one(abs / 1e9)}B` : abs >= 1e6 ? `${one(abs / 1e6)}M` : `${one(abs / 1e3)}K`;
+  return `${pre.trim()}${pre.trim() ? ' ' : ''}${n < 0 ? '-' : ''}${body}`.trim();
+}

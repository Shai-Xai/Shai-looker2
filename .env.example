LOOKER_BASE_URL=https://your-company.looker.com
LOOKER_CLIENT_ID=your_client_id_here
LOOKER_CLIENT_SECRET=your_client_secret_here
PORT=3000

# First-run admin account (seeded only if no users exist yet).
ADMIN_EMAIL=admin@howler.co.za
ADMIN_PASSWORD=change_me_after_first_login

# Optional: secret used to sign session cookies. If unset, a random one is
# generated and saved to server/data/.session-secret. Set it explicitly in
# production so sessions survive across deploys.
# SESSION_SECRET=some_long_random_string
